# Set default behavior to automatically normalize line endings
* text=auto

# Force bash scripts to always use LF line endings 
*.sh text eol=lf

# Force batch scripts to always use CRLF line endings
*.bat text eol=crlf
*.cmd text eol=crlf

# Force Python files to use LF
*.py text eol=lf

# HTML, JS, CSS with LF
*.html text eol=lf
*.js text eol=lf
*.css text eol=lf

# Text files should have LF
*.md text eol=lf
*.txt text eol=lf

# Binary files - don't modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.gz binary
*.zip binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
